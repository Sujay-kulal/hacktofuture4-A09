DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/selfheal
SELFHEAL_KUBE_MODE=mock
SELFHEAL_TELEMETRY_MODE=live
PROMETHEUS_URL=http://127.0.0.1:9090
LOKI_URL=http://127.0.0.1:3100
TRACE_URL=http://127.0.0.1:3200
TRACE_BACKEND=tempo
SELFHEAL_NAMESPACE=demo
SELFHEAL_BACKGROUND_MONITORING=true
SELFHEAL_MONITOR_INTERVAL_SECONDS=30
SELFHEAL_MONITOR_NAMESPACES=default,monitoring
GEMINI_API_KEY=your_google_ai_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash
GEMINI_MAX_RETRIES=3
SELFHEAL_AUTOMATION_MODE=hybrid
